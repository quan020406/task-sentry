# 依赖（容器内重新安装）
node_modules/

# 构建产物（容器内重新构建）
dist/

# 环境变量（禁止打包进镜像）
.env
.env.local
.env.*.local

# 版本控制
.git/
.gitignore

# 编辑器与系统文件
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# 日志
*.log
npm-debug.log*

# TypeScript 增量构建缓存
*.tsbuildinfo

# Vite 缓存
.vite/

# 构建中间产物
vite.config.js
vite.config.d.ts
