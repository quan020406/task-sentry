# 服务端口
PORT=3000

# JWT 密钥（生产环境请使用强随机字符串）
JWT_SECRET=your_jwt_secret_change_me_in_production

# JWT 过期时间
JWT_EXPIRES_IN=7d

# 游客 token 过期时间
GUEST_JWT_EXPIRES_IN=1d

# 游客每日免费扫描次数
GUEST_DAILY_LIMIT=3

# 数据库文件路径
DB_PATH=./data/app.db

# ===== AI 服务配置（S06 阶段启用） =====
# AI 服务提供方：doubao / wenxin / deepseek / openai / mock（默认 mock，不调用真实 API）
AI_PROVIDER=mock

# API Key（必填，除非使用 mock 模式）
AI_API_KEY=

# Base URL（可选，留空则使用 provider 默认地址）
# - doubao:  https://ark.cn-beijing.volces.com/api
# - wenxin:  https://qianfan.baidubce.com/v2
# - deepseek: https://api.deepseek.com
# - openai:  https://api.openai.com
AI_BASE_URL=

# 模型名称（可选，留空则使用 provider 默认模型）
# - doubao:  doubao-pro-32k-241105
# - wenxin:  ernie-4.0-8k-latest
# - deepseek: deepseek-chat
# - openai:  gpt-4o-mini
AI_MODEL=

# 温度（0-1，默认 0.7）
AI_TEMPERATURE=0.7

# 最大输出 token（默认 2000）
AI_MAX_TOKENS=2000

# 每日 token 上限（0 表示不限制，超额自动降级到 mock）
AI_DAILY_TOKEN_LIMIT=0

# 前端地址（CORS 白名单）
CLIENT_ORIGIN=http://localhost:5173
