# 《先别开工》Docker 部署环境变量模板
# 用法：
#   1. 复制本文件为 .env.docker
#   2. 修改下方配置（特别是 JWT_SECRET 必须修改！）
#   3. 启动：docker compose --env-file .env.docker up -d

# ===== 前端端口（宿主机访问端口）=====
FRONTEND_PORT=80

# ===== JWT 密钥（务必修改为强随机字符串！）=====
# 生成命令：openssl rand -hex 32
JWT_SECRET=please_change_me_to_a_strong_random_string

# ===== JWT 过期时间 =====
JWT_EXPIRES_IN=7d

# ===== 游客 token 过期时间 =====
GUEST_JWT_EXPIRES_IN=1d

# ===== 游客每日免费扫描次数 =====
GUEST_DAILY_LIMIT=3

# ===== 前端地址（CORS 白名单）=====
# 生产环境改为实际域名，如 https://example.com
CLIENT_ORIGIN=http://localhost

# ===== AI 服务配置 =====
# 提供方：mock / doubao / wenxin / deepseek / openai
# mock 模式不调用真实 API，适合演示和测试
AI_PROVIDER=mock

# API Key（使用真实 AI 时必填）
AI_API_KEY=

# Base URL（可选，留空用默认）
AI_BASE_URL=

# 模型名称（可选，留空用默认）
AI_MODEL=

# 温度（0-1）
AI_TEMPERATURE=0.7

# 最大输出 token
AI_MAX_TOKENS=2000

# 每日 token 上限（0 表示不限制，超额降级到 mock）
AI_DAILY_TOKEN_LIMIT=0
